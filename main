local HttpService = game:GetService("HttpService")
local StarterGui = game:GetService("StarterGui")

local API = "https://keys.j2trapz67.workers.dev/"


local function Notify(title, text)

    pcall(function()

        StarterGui:SetCore(
            "SendNotification",
            {
                Title = title,
                Text = text,
                Duration = 5
            }
        )

    end)

end



local Key = getgenv().ScriptKey


if not Key then

    Notify(
        "Axiom Key System",
        "❌ No key provided"
    )

    warn("No key provided")

    return

end



local success, response = pcall(function()

    return request({

        Url = API,

        Method = "POST",

        Headers = {
            ["Content-Type"] = "application/json"
        },

        Body = HttpService:JSONEncode({

            action = "verify",

            key = Key

        })

    })

end)



if not success then

    Notify(
        "Axiom Key System",
        "❌ Failed connecting to server"
    )

    warn("Failed connecting to key server")

    return

end



local data = HttpService:JSONDecode(response.Body)



if not data.success then

    Notify(
        "Axiom Key System",
        "❌ Invalid or expired key"
    )

    warn("Invalid key")

    return

end



Notify(
    "Axiom Key System",
    "✅ Key verified! Loading..."
)


print("✅ Key verified")



task.wait(1)


loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/x1617018-cmyk/poop/refs/heads/main/poopy"
))()
