local HttpService = game:GetService("HttpService")

local API = "https://keys.j2trapz67.workers.dev/"

local ScriptURL = "https://raw.githubusercontent.com/x1617018-cmyk/poop/refs/heads/main/poopy"

-- Put the user's key here


local function VerifyKey()

    local success, response = pcall(function()

        return request({
            Url = API,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode({
                action = "verify",
                key = Key
            })
        })

    end)


    if not success then
        warn("API connection failed")
        return false
    end


    local data = HttpService:JSONDecode(response.Body)

    return data.success == true
end



if VerifyKey() then

    print("Key valid - loading script")

    local success, code = pcall(function()

        return game:HttpGet(ScriptURL)

    end)


    if success then

        loadstring(code)()

    else

        warn("Failed loading script")

    end


else

    warn("Invalid key")

end
