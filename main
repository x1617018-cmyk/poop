
local HttpService = game:GetService("HttpService")

local API = "https://keys.j2trapz67.workers.dev/"


local Key = getgenv().ScriptKey


if not Key then
    warn("No key provided")
    return
end



local success, response = pcall(function()

    return request({

        Url = API,

        Method = "POST",

        Headers = {
            ["Content-Type"] = "application/json"
        },

        Body = HttpService:JSONEncode({

            action = "verify",

            key = Key

        })

    })

end)



if not success then

    warn("Failed connecting to key server")
    return

end



local data = HttpService:JSONDecode(response.Body)



if not data.success then

    warn("Invalid key")
    return

end



print("✅ Key verified")

loadstring(game:HttpGet("https://raw.githubusercontent.com/x1617018-cmyk/poop/refs/heads/main/poopy"))()
